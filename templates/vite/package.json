{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev:all": "concurrently -n web,server -c cyan,yellow \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite dev",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:server": "tsc -p server/tsconfig.build.json",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "node build/server/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "test \"$NODE_ENV\" = \"production\" || husky || exit 0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.16.5",
    "@types/react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.7.3",
    "prisma": "^6.16.3",
    "tsx": "^4.22.2",
    "typescript-eslint": "^8.56.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [ "eslint --fix", "prettier --write" ],
    "*.{json,css,md}": [ "prettier --write" ]
  }
}
